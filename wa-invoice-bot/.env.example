# ─────────── Supabase ───────────
# Sandbox (jisr-dev) — use this for testing. Switch to prod when ready.
SUPABASE_URL=https://zqkweecwbsjxseelrirr.supabase.co
# Service-role key: Supabase dashboard → Project Settings → API → service_role (secret).
# The bot needs it to read invoice data (RLS) and drive the outbox. KEEP THIS SECRET — never commit .env.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────── Target WhatsApp group ───────────
# After scanning the QR once, run:  npm run list-groups
# It prints every group's name + id. Then set ONE of these (WA_GROUP_ID is the most reliable):
# WA_GROUP_ID=120363000000000000@g.us
WA_GROUP_NAME=

# ─────────── Timing (Riyadh) ───────────
POLL_SEC=20             # how often to check the outbox
RIPEN_SEC=60            # wait this long after an event before sending (lets the first payment fold into the creation message)
SUMMARY_PREVIEW_HOUR=1  # preliminary daily summary at 01:00
SUMMARY_FINAL_HOUR=5    # corrected final summary at 05:0X (only if something changed after 01:00)
SUMMARY_FINAL_MINUTE=5

# ─────────── Anti-ban pacing (ms between sends) ───────────
SEND_DELAY_MIN=3000
SEND_DELAY_MAX=8000
